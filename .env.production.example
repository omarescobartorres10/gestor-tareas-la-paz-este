# INSTRUCCIONES DE CONFIGURACIÓN PARA PRODUCCIÓN
# Copia estas variables a tu archivo .env principal para mejorar el rendimiento

# Environment
APP_ENV=production
APP_DEBUG=false

# Logging - Solo errores en producción
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

# Debugbar - DESHABILITADO en producción
DEBUGBAR_ENABLED=false

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Cache
CACHE_STORE=file

# Las demás configuraciones (DB, APP_KEY, etc.) mantén las que ya tienes
